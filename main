-- ================== AUTO MINI GAME ==================
task.spawn(function()

    local gui = workspace.Game.DigCooldown.Board.SurfaceGui
    local timeText = gui.Timer
    local progressText = gui.Bar.Progress
    local inventoryHidden = false

    local cursor = player.PlayerGui.Minigames.Main.Cursor
    local hit = player.PlayerGui.Minigames.Main.CanvasGroup.Hit

    local targetPos = Vector3.new(92.8, 3508.5, 378)

    local claimed = false

    local function round(n)
        return math.floor(n + 0.5)
    end

    local function isAtTarget()
        local char = player.Character
        if not char then return false end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return false end

        local pos = hrp.Position
        return round(pos.X) == round(targetPos.X)
            and round(pos.Y) == round(targetPos.Y)
            and round(pos.Z) == round(targetPos.Z)
    end

    local function clickDig()
        pcall(function()
            mousemoveabs(1050,100)
            mouse1click()
        end)
    end

    local function clickClaim()
    pcall(function()
        local x, y = 570, 452
        mousemoveabs(x, y)
        task.wait(0.05)
        mouse1press()
        task.wait(0.01)

        -- giữ chuột tại chỗ (chống trượt)
        mousemoveabs(x, y)

        mouse1release()
    end)
end

    while true do
        task.wait(0.1) -- 🔥 theo đúng yêu cầu của bạn

        local timeValue = timeText.Text
        local progressValue = progressText.Text

        local isStart = timeValue and timeValue:lower():find("start")

        local current, max = progressValue:match("(%d+)%s*/%s*(%d+)")
        current = tonumber(current)
        max = tonumber(max)

        -- =========================
        -- 🧠 LOGIC GỐC (GIỮ NGUYÊN)
        -- =========================
        local shouldAuto = false

        if isStart then
            shouldAuto = true
        else
            if current and max and current >= max then
                shouldAuto = false
            else
                shouldAuto = true
            end
        end

        -- =========================
        -- 🔥 ENTER MINI GAME MODE
        -- =========================
        if shouldAuto then
            requestMode("MINIGAME")
        end
    end
end)

-- ================== AUTO POTION SCHEDULER ==================
task.spawn(function()

    -- 🔥 chạy 1 lần khi start
    task.wait(5)
    requestMode("POTION")

  while true do
       local now = os.time()

      local potionQueued = false

   local gems = getGems()

for _, slot in pairs({1,3,10}) do
    if os.time() >= nextBuyTime[slot] then

        local price = potionPrices[slot] or 0

        if gems and price and gems >= price then

            if not potionQueued then
                print("🧪 READY + ĐỦ GEMS -> BUY SLOT", slot)
                requestMode("POTION")
                potionQueued = true
            end

        else
            print("💸 KHÔNG ĐỦ GEMS | SLOT:", slot, "| Gems:", gems, "| Price:", price)
        end

    end
end

      task.wait(2) -- check nhẹ thôi (KHÔNG spam)
    end

end)
