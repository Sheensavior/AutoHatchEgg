end)

-- ================== MINI GAME RUNNER ==================
local function runMiniGame()

    AutoSystem.autoClick = false

    local gui = workspace.Game.DigCooldown.Board.SurfaceGui
    local timeText = gui.Timer
    local progressText = gui.Bar.Progress

    local cursor = player.PlayerGui.Minigames.Main.Cursor
    local hit = player.PlayerGui.Minigames.Main.CanvasGroup.Hit

    local targetPos = Vector3.new(92.8, 3508.5, 378)

    local function round(n)
        return math.floor(n + 0.5)
    end

    local function isAtTarget()
        local char = player.Character
        if not char then return false end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return false end

        local pos = hrp.Position
        return round(pos.X) == round(targetPos.X)
            and round(pos.Y) == round(targetPos.Y)
            and round(pos.Z) == round(targetPos.Z)
    end

    local function clickDig()
        pcall(function()
            mousemoveabs(1050,100)
            mouse1click()
        end)
    end

    local function clickClaim()
        pcall(function()
            mousemoveabs(565,599)
            mouse1click()
        end)
    end

    local claimed = false

    while true do
        task.wait(0.1)

        local timeValue = timeText.Text
        local progressValue = progressText.Text

        local isStart = timeValue and timeValue:lower():find("start")

        local current, max = progressValue:match("(%d+)%s*/%s*(%d+)")
        current = tonumber(current)
        max = tonumber(max)

        if isStart or (current and max and current < max) then

            if isAtTarget() then

                setInventory(false)

                local cursorCenter = cursor.AbsolutePosition.X + cursor.AbsoluteSize.X / 2
                local hitMin = hit.AbsolutePosition.X
                local hitMax = hitMin + hit.AbsoluteSize.X

                if cursorCenter >= hitMin and cursorCenter <= hitMax then
                    clickDig()
                end

            else
                local char = player.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    char.HumanoidRootPart.CFrame = CFrame.new(targetPos)
                end
            end

        else
            if not claimed and current and max and current >= max then
                claimed = true
                task.wait(0.2)
                clickClaim()
            end

            break
        end
    end

    AutoSystem.autoClick = true
end

