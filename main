        main.Size = UDim2.new(0,200,0,40)
    else
        main.Size = UDim2.new(0,380,0,470)
    end
end)
------------------------------------------------------
local function switchTab(tab)
    if tab == "AUTO" then
        autoFrame.Visible = true
        upgradeFrame.Visible = false

        autoTab.BackgroundColor3 = Color3.fromRGB(0,170,100)
        upgradeTab.BackgroundColor3 = Color3.fromRGB(40,40,40)

    elseif tab == "UPGRADE" then
        autoFrame.Visible = false
        upgradeFrame.Visible = true

        upgradeTab.BackgroundColor3 = Color3.fromRGB(0,170,100)
        autoTab.BackgroundColor3 = Color3.fromRGB(40,40,40)
    end
end

autoTab.MouseButton1Click:Connect(function()
    switchTab("AUTO")
end)

upgradeTab.MouseButton1Click:Connect(function()
    switchTab("UPGRADE")
end)
-- UI UPDATE
local function updateUI()
    toggle.Text = AutoSystem.enabled and "ON" or "OFF"
    toggle.BackgroundColor3 = AutoSystem.enabled and Color3.fromRGB(0,170,100) or Color3.fromRGB(170,0,0)

    autoClickBtn.Text = AutoSystem.autoClick and "AUTO CLICK: ON" or "AUTO CLICK: OFF"
    autoClickBtn.BackgroundColor3 = AutoSystem.autoClick and Color3.fromRGB(0,170,100) or Color3.fromRGB(170,0,0)
    modeLabel.Text = "Mode: " .. CurrentMode

    if not input:IsFocused() then
    input.Text = tostring(AutoSystem.eggAmount)
    end
end

updateUI()

task.spawn(function()
    while true do

        updateUI()

        local now = os.time()

        local t1 = formatTime(nextBuyTime[1] - now)
        local t3 = formatTime(nextBuyTime[3] - now)
        local t10 = formatTime(nextBuyTime[10] - now)

        potionLabel.Text =
            "Potion 1: " .. t1 .. "\n" ..
            "Potion 3: " .. t3 .. "\n" ..
            "Potion 10: " .. t10

        task.wait(1)

    end
end)

autoClickBtn.MouseButton1Click:Connect(function()
    AutoSystem.autoClick = not AutoSystem.autoClick
    updateUI()
end)

toggle.MouseButton1Click:Connect(function()
    AutoSystem.enabled = not AutoSystem.enabled
    saveData()
    updateUI()
end)

input.FocusLost:Connect(function()
    local num = tonumber(input.Text)
    if num then
        AutoSystem.eggAmount = math.clamp(num,1,99)
        saveData()
    end
    updateUI()
end)
