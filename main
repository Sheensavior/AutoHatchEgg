        end
    end
end)
-- ================== AUTO MINI GAME ==================
task.spawn(function()

    local gui = workspace.Game.DigCooldown.Board.SurfaceGui
    local timeText = gui.Timer
    local progressText = gui.Bar.Progress
    local inventoryHidden = false

    local cursor = player.PlayerGui.Minigames.Main.Cursor
    local hit = player.PlayerGui.Minigames.Main.CanvasGroup.Hit

    local targetPos = Vector3.new(92.8, 3508.5, 378)

    local claimed = false

    local function round(n)
        return math.floor(n + 0.5)
    end

    local function isAtTarget()
        local char = player.Character
        if not char then return false end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return false end

        local pos = hrp.Position
        return round(pos.X) == round(targetPos.X)
            and round(pos.Y) == round(targetPos.Y)
            and round(pos.Z) == round(targetPos.Z)
    end

    local function clickDig()
        pcall(function()
            mousemoveabs(1050,100)
            mouse1click()
        end)
    end

    local function clickClaim()
        pcall(function()
            mousemoveabs(565,599)
            mouse1click()
        end)
    end

    while true do
        task.wait(0.1) -- 🔥 theo đúng yêu cầu của bạn

        local timeValue = timeText.Text
        local progressValue = progressText.Text

        local isStart = timeValue and timeValue:lower():find("start")

        local current, max = progressValue:match("(%d+)%s*/%s*(%d+)")
        current = tonumber(current)
        max = tonumber(max)

        -- =========================
        -- 🧠 LOGIC GỐC (GIỮ NGUYÊN)
        -- =========================
        local shouldAuto = false

        if isStart then
            shouldAuto = true
        else
            if current and max and current >= max then
                shouldAuto = false
            else
                shouldAuto = true
            end
        end

        -- =========================
        -- 🔥 ENTER MINI GAME MODE
        -- =========================
        if shouldAuto then
            requestMode("MINIGAME")
        end
    end
end)

-- ================== AUTO POTION SCHEDULER ==================
task.spawn(function()

    -- 🔥 chạy 1 lần khi start
    task.wait(5)
    requestMode("POTION")

    while true do
        local now = os.time()

       local potionQueued = false

        for _, slot in pairs({1,3,10}) do
        if os.time() >= nextBuyTime[slot] then
            if not potionQueued then
            requestMode("POTION")
            potionQueued = true
        end
    end
end

        task.wait(5) -- check nhẹ thôi (KHÔNG spam)
    end

end)

-- ================== MINI GAME RUNNER ==================
local function runMiniGame()

    AutoSystem.autoClick = false

    local gui = workspace.Game.DigCooldown.Board.SurfaceGui
    local timeText = gui.Timer
    local progressText = gui.Bar.Progress

    local cursor = player.PlayerGui.Minigames.Main.Cursor
    local hit = player.PlayerGui.Minigames.Main.CanvasGroup.Hit

    local targetPos = Vector3.new(92.8, 3508.5, 378)

    local function round(n)
        return math.floor(n + 0.5)
    end

    local function isAtTarget()
        local char = player.Character
        if not char then return false end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return false end

        local pos = hrp.Position
        return round(pos.X) == round(targetPos.X)
            and round(pos.Y) == round(targetPos.Y)
            and round(pos.Z) == round(targetPos.Z)
    end

    local function clickDig()
        pcall(function()
            mousemoveabs(1050,100)
            mouse1click()
        end)
    end

    local function clickClaim()
        pcall(function()
            mousemoveabs(565,599)
            mouse1click()
        end)
    end

    local claimed = false

    while true do
        task.wait(0.1)

        local timeValue = timeText.Text
        local progressValue = progressText.Text

        local isStart = timeValue and timeValue:lower():find("start")

        local current, max = progressValue:match("(%d+)%s*/%s*(%d+)")
        current = tonumber(current)
        max = tonumber(max)

        if isStart or (current and max and current < max) then

            if isAtTarget() then

                setInventory(false)

                local cursorCenter = cursor.AbsolutePosition.X + cursor.AbsoluteSize.X / 2
                local hitMin = hit.AbsolutePosition.X
                local hitMax = hitMin + hit.AbsoluteSize.X

                if cursorCenter >= hitMin and cursorCenter <= hitMax then
                    clickDig()
                end

            else
                local char = player.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    char.HumanoidRootPart.CFrame = CFrame.new(targetPos)
                end
            end

        else
            if not claimed and current and max and current >= max then
                claimed = true
                task.wait(0.2)
                clickClaim()
            end

            break
        end
    end

    AutoSystem.autoClick = true
end

-- ================== RAINBOW RUNNER ==================

local function runRainbow()

    setInventory(true)
    waitForInventoryLoad(6)

    while true do
        local golden = getGoldenPets()
        if #golden < 5 then break end

        tp(POSITIONS.RAINBOW)
        task.wait(1.5)

        setInventory(false)
        task.wait(0.5)
        setInventory(true)
        waitForInventoryLoad(3)

        local ids = {
            golden[1], golden[2], golden[3],
            golden[4], golden[5]
        }

        startRainbow:InvokeServer(ids)
        task.wait(30)

        claimRainbow:InvokeServer(ids[1])
        task.wait(1)
    end

    setInventory(false)
end
-- ================== POTION RUNNER ==================
local function runPotion()

    print("🧪 Run Potion Mode")

    teleportToPotion()

    -- 🔥 ĐỢI UI LOAD THẬT SỰ
    local potionMenu = player.PlayerGui:WaitForChild("Tabs")
        :WaitForChild("PotionMachine")
        :WaitForChild("Menu")

    -- đợi UI ổn định
    task.wait(2.5)

    -- 🔥 BƯỚC 1: ĐỌC TOÀN BỘ TEXT TRƯỚC
    local texts = {}

    for _, slot in pairs({1,3,10}) do
        local success, path = pcall(function()
            return potionMenu.BuyOptions["Buy"..slot].Main.Cooldown
        end)

        if success and path then
            texts[slot] = path.Text
            print("📥 SLOT", slot, "TEXT:", texts[slot])
        else
            warn("❌ Không đọc được slot:", slot)
        end
    end

    -- 🔥 BƯỚC 2: XỬ LÝ SAU KHI ĐÃ CÓ TEXT
    for _, slot in pairs({1,3,10}) do
        if texts[slot] then
            handlePotion(slot, texts[slot])
        end
    end

end

-- ================== MAIN LOOP ==================
task.spawn(function()
    while true do

        if CurrentMode == "EGG" then
            CurrentMode = getNextMode()
            updateUI()
        end
        if CurrentMode == "POTION" then
            runPotion()
            CurrentMode = "EGG"

        elseif CurrentMode == "MINIGAME" then
            runMiniGame()
            CurrentMode = "EGG"

        elseif CurrentMode == "RAINBOW" then
            runRainbow()
            CurrentMode = "EGG"

        elseif CurrentMode == "EGG" then

            if AutoSystem.enabled then

                local ids = getPets()

                if AutoSystem.mode == "EGG" then
                    tp(POSITIONS.EGG)

                    if #ids >= 6 then
                        AutoSystem.mode = "GOLDEN"
                    elseif hatchFolder then
                        hatchFolder.Functions.OpenEgg:InvokeServer("Spring Blossom", AutoSystem.eggAmount)
                    end

                elseif AutoSystem.mode == "GOLDEN" then
                    tp(POSITIONS.GOLDEN)

                    if #ids >= 6 and craftRemote then
                        craftRemote:InvokeServer({
                            ids[1], ids[2], ids[3],
                            ids[4], ids[5], ids[6]
                        })
                    else
                        AutoSystem.mode = "EGG"
                    end
                end

            end
        end

        task.wait(0.5)
    end
end)

-- ================== AUTO CLICK ==================
task.spawn(function()
    local baseX, baseY = 1050, 100

    while true do
        if AutoSystem.autoClick then
            pcall(function()
                local offsetX = math.random(-5,5)
                local offsetY = math.random(-5,5)

                mousemoveabs(baseX + offsetX, baseY + offsetY)
                mouse1click()
            end)
        end
        task.wait(0.05)
    end
end)

end
