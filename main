unlockBtn.MouseButton1Click:Connect(function()

    print("🔓 Unlocking Portal...")

    local portals = {
        "Forest","Winter","Desert","Jungle",
        "Heaven","Dojo","Volcano","Candy",
        "Atlantis","Space"
    }

    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = CFrame.new(-154,239,370)
    end

    task.wait(1)

    -- 🔹 MUA PORTAL
    for _, name in ipairs(portals) do
        pcall(function()
            game:GetService("ReplicatedStorage")
                :WaitForChild(game.JobId)
                :WaitForChild("Functions")
                :WaitForChild("BuyPortal")
                :InvokeServer(name)
        end)

        task.wait(0.3)
    end

    -- 🔥 THÊM ĐOẠN NÀY (MUA WORLD)
    print("🌍 Buying World...")

    local success, err = pcall(function()
        game:GetService("ReplicatedStorage")
            :WaitForChild(game.JobId)
            :WaitForChild("Functions")
            :WaitForChild("BuyWorld")
            :InvokeServer("Space")
    end)

    if not success then
        warn("❌ BuyWorld lỗi:", err)
    else
        print("✅ Bought World: Space")
    end

    print("✅ Done")
end)
