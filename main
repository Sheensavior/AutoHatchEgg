            claimRainbow = f.ClaimRainbow
        end
    end
end

-- ================== AUTO USE POTION ==================
task.spawn(function()

    local player = game.Players.LocalPlayer

    local function getHolder()
        local success, result = pcall(function()
            return player
                :WaitForChild("PlayerGui")
                :WaitForChild("RightHud")
                :WaitForChild("Main")
                :WaitForChild("RightUI")
                :WaitForChild("Items")
                :WaitForChild("List")
                :WaitForChild("Holder")
        end)

        return success and result or nil
    end

    local Keywords = { "potion", " i", " ii", " iii", "luck20" }
    local Blacklist = { "vip", "shop", "category" }

    local function matchAny(str, list)
        for _, v in pairs(list) do
            if string.find(str, v) then
                return true
            end
        end
        return false
    end

    local function matchPattern(str, patterns)
        for _, p in pairs(patterns) do
            if string.match(str, p) then
                return true
            end
        end
        return false
    end

    local function check(name)
        local lower = string.lower(name)
        return matchAny(lower, Keywords) and not matchPattern(lower, Blacklist)
    end

    local ReplicatedStorage = game:GetService("ReplicatedStorage")

    local function getRemote()
        local success, result = pcall(function()
            return ReplicatedStorage:WaitForChild(game.JobId)
                :WaitForChild("Functions")
                :WaitForChild("UseBoost")
        end)

        return success and result or nil
    end

    while true do

        -- 🔥 CHẠY NGAY
        local holder = getHolder()
        local remote = getRemote()

        if holder and remote then
            local used = {}

            for _, obj in pairs(holder:GetChildren()) do
                if obj:IsA("ImageButton") or obj:IsA("Frame") then

                    local name = obj.Name

                    if check(name) and not used[name] then
                        used[name] = true

                        pcall(function()
                            remote:InvokeServer(name)
                        end)

                        task.wait(0.2)
                    end
                end
            end
        end

        -- ⏱ SAU ĐÓ MỚI ĐỢI
        task.wait(60)

    end

end)

-- ================== AUTO BUY GEM MERCHANT ==================
task.spawn(function()

    local player = game.Players.LocalPlayer
    local rs = game:GetService("ReplicatedStorage")

    local function getList()
        local success, result = pcall(function()
            return player
                :WaitForChild("PlayerGui")
                :WaitForChild("Tabs")
                :WaitForChild("Merchant")
                :WaitForChild("Menu")
                :WaitForChild("Inner")
                :WaitForChild("List")
        end)

        return success and result or nil
    end

    local function getRemote()
        local success, result = pcall(function()
            return rs
                :WaitForChild(game.JobId)
                :WaitForChild("Functions")
                :WaitForChild("PurchaseMerchantItem")
        end)

        return success and result or nil
    end

    local function isAvailable(item)
        local stock = item:FindFirstChild("Stock", true)
        if not stock or not stock:IsA("TextLabel") then
            return false
        end

        local text = string.upper(stock.Text)

        if string.find(text, "SOLD") then
            return false
        end

        return true
    end

    while true do

        -- 🔥 CHẠY NGAY
        local list = getList()
        local remote = getRemote()

        if list and remote then

            for _, item in pairs(list:GetChildren()) do
                if item:IsA("Frame") then

                    local name = item.Name
                    local lower = string.lower(name)

                    -- lọc Potion
                    if string.find(lower, "potion") then

                        if isAvailable(item) then
                            print("🧪 BUY GEM:", name)

                            pcall(function()
                                remote:InvokeServer("GemMerchant", name)
                            end)

                            task.wait(0.3)
                        else
                            print("❌ SOLD OUT:", name)
                        end
                    end
                end
            end

        end

        -- ⏱ loop nhẹ
        task.wait(10)

    end

end)

-- ================== INVENTORY ==================
local inventoryUI = player.PlayerGui
    :WaitForChild("Tabs")
    :WaitForChild("Inventory")

local container = inventoryUI
    :WaitForChild("Menu")
    :WaitForChild("Categories")
    :WaitForChild("Pets")
    :WaitForChild("Inner")
    :WaitForChild("List")
    :WaitForChild("Container")

local function setInventory(state)
    inventoryUI.Enabled = state
end

local function waitForInventoryLoad(timeout)
    timeout = timeout or 5
    local start = tick()

    while tick() - start < timeout do
        for _, pet in pairs(container:GetChildren()) do
            if pet.Name == PET_NAME then
                local grad = pet:FindFirstChild("UIGradient")
                if grad and grad.Color then
                    return true
                end
            end
        end
        task.wait(0.2)
    end

    warn("⚠️ Inventory load timeout")
    return false
end

-- ================== GET PET ==================
local function getPets()
    local ids = {}
    for _, pet in pairs(container:GetChildren()) do
        if pet.Name == PET_NAME and pet:FindFirstChild("Mythical") then
            local id = pet:GetAttribute("Id")
            if id then table.insert(ids, id) end
        end
    end
    return ids
end

local function isGolden(pet)
    local grad = pet:FindFirstChild("UIGradient")
    if not grad then return false end

    for _, kp in pairs(grad.Color.Keypoints) do
        if kp.Value.R > 0.95 then
            return true
        end
    end
    return false
end

local function getGoldenPets()
    local list = {}
    for _, pet in pairs(container:GetChildren()) do
        if pet.Name == PET_NAME and not pet:FindFirstChild("Mythical") then
            if isGolden(pet) then
                local id = pet:GetAttribute("Id")
                if id then table.insert(list, id) end
            end
        end
    end
    return list
end

-- ================== TELEPORT ==================
local function tp(pos)
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = CFrame.new(pos)
    end
end
