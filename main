-- ================== POTION SYSTEM ==================

local POTION_POS = Vector3.new(-206.6, 9198.5, 159.8)

local nextBuyTime = {
    [1] = 0,
    [3] = 0,
    [10] = 0
}
-- 💰 LƯU GIÁ POTION
local potionPrices = {
    [1] = 0,
    [3] = 0,
    [10] = 0
}

-- 🔢 PARSE SỐ
local suffixMultiplier = {
    k = 1e3,
    m = 1e6,
    b = 1e9,
    t = 1e12,
    qd = 1e15,
    qn = 1e18,
    sx = 1e21
}

local function parseNumber(text)
    if not text then return nil end

    text = string.lower(text)

    local number, suffix = string.match(text, "([%d%.]+)%s*(%a+)")
    if not number then
        return tonumber(text) -- fallback nếu là số thường
    end

    number = tonumber(number)
    if not number then return nil end

    if suffix and suffixMultiplier[suffix] then
        return number * suffixMultiplier[suffix]
    end

    return number
end

-- 💎 LẤY GEMS
local function getGems()
    local success, label = pcall(function()
        return player.PlayerGui
            :WaitForChild("Tabs")
            :WaitForChild("Upgrades2")
            :WaitForChild("Menu")
            :WaitForChild("Tabs")
            :WaitForChild("Gems")
            :WaitForChild("Amount")
    end)

    if success and label then
        return parseNumber(label.Text)
    end

    return 0
end

local function teleportToPotion()
    tp(POTION_POS)
end
local function isCooldownRunning(label)
    local t1 = label.Text
    task.wait(1)
    local t2 = label.Text

    return t1 ~= t2
end
-------------------------------------------
local function hmsToSeconds(str)
    local total = 0

    local h = str:match("(%d+)h")
    local m = str:match("(%d+)m")
    local s = str:match("(%d+)s")

    if h then total += tonumber(h) * 3600 end
    if m then total += tonumber(m) * 60 end
    if s then total += tonumber(s) end

    return total
end
----------------------------------------------
local function formatTime(sec)
    if sec <= 0 then return "READY" end

    local d = math.floor(sec / 86400)
    local h = math.floor((sec % 86400) / 3600)
    local m = math.floor((sec % 3600) / 60)
    local s = sec % 60

    if d > 0 then
        return string.format("%dd %dh %dm %ds", d, h, m, s)
    elseif h > 0 then
        return string.format("%dh %dm %ds", h, m, s)
    elseif m > 0 then
        return string.format("%dm %ds", m, s)
    else
        return string.format("%ds", s)
    end
end
--------------------------------------------------
local function buyPotion(amount)
    game:GetService("ReplicatedStorage")
        :WaitForChild(game.JobId)
        :WaitForChild("Functions")
        :WaitForChild("BuyPotionMachine")
        :InvokeServer(amount)
end

local function handlePotion(slot, text)
    local label = player.PlayerGui.Tabs.PotionMachine.Menu.BuyOptions["Buy"..slot].Main.Cooldown

    if not isCooldownRunning(label) then
        print("✅ SLOT "..slot.." READY -> BUY")

        buyPotion(slot)

        -- đợi UI đổi sang cooldown mới
        local timeout = tick() + 5
        repeat
            task.wait(0.2)
        until isCooldownRunning(label) or tick() > timeout

        local text = text or label.Text
        local seconds = hmsToSeconds(text)

        nextBuyTime[slot] = os.time() + seconds

    else
        local text = label.Text
        local seconds = hmsToSeconds(text)

        nextBuyTime[slot] = os.time() + seconds
    end
end

-- ================== TRADE ==================
local IDServer = nil
for _, v in pairs(rs:GetChildren()) do
    if v:FindFirstChild("Functions") and v:FindFirstChild("Events") then
        IDServer = v.Name
        break
    end
end

local function getTradePets()
    local petFolder = player.PlayerGui:WaitForChild("Trading")
        :WaitForChild("Trading")
        :WaitForChild("You")
        :WaitForChild("Inner")
        :WaitForChild("MainList")

    local pets = {}

    for _, v in pairs(petFolder:GetChildren()) do
        if v.Name ~= "UIGridLayout" and v.Name ~= "AddPass" then
            table.insert(pets, v.Name)
        end
    end

    return pets
end

local function tradePets(amount)
    local pets = getTradePets()

    if not IDServer then
        warn("Không có ID Server!")
        return
    end

    if #pets == 0 then
        warn("Không có pet!")
        return
    end

    for i = 1, amount do
        local petID = pets[i]
        if not petID then break end

        local args = {
            {
                "Pet",
                petID
            }
        }

        rs:WaitForChild(IDServer)
            :WaitForChild("Functions")
            :WaitForChild("AddTradeItem")
            :InvokeServer(unpack(args))

        task.wait(0.2)
    end
end
---------------------------------------------------------------------
local function runUpgradeGem()

    local player = game.Players.LocalPlayer
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")

    -- 🔥 TELEPORT TRƯỚC KHI UPGRADE
    hrp.CFrame = CFrame.new(-212, 2544, 391)

    task.wait(0.5) -- đợi ổn định (rất quan trọng)

    local JobID = game.JobId

    local remote = game:GetService("ReplicatedStorage")
        :WaitForChild(JobID)
        :WaitForChild("Functions")
        :WaitForChild("UpgradeGemShop")

    -- 📌 danh sách + số lần
    local upgrades = {
        {Name = "FreeAutoClicker", Amount = 1},
        {Name = "HatchSpeed", Amount = 5},
        {Name = "CriticalChance", Amount = 5},
        {Name = "GoldenLuck", Amount = 6},
        {Name = "AutoClickerSpeed", Amount = 11},
        {Name = "ClickMultiplier", Amount = 20},
        {Name = "Teleport", Amount = 1},
    }

    for _, data in ipairs(upgrades) do
        local NameUpgradeGems = data.Name

        for i = 1, data.Amount do

            local success, err = pcall(function()
                remote:InvokeServer(NameUpgradeGems)
            end)

            if not success then
                warn("❌ lỗi:", NameUpgradeGems, err)
                break
            end

            print("⬆️", NameUpgradeGems, "(", i, "/", data.Amount, ")")

            task.wait(0.2)
        end
    end

    print("✅ DONE UPGRADE GEM")

end

