-- ================== RAINBOW RUNNER ==================

local function runRainbow()

    setInventory(true)
    waitForInventoryLoad(6)

    while true do
        local golden = getGoldenPets()
        if #golden < 5 then break end

        tp(POSITIONS.RAINBOW)
        task.wait(1.5)

        setInventory(false)
        task.wait(0.5)
        setInventory(true)
        waitForInventoryLoad(3)

        local ids = {
            golden[1], golden[2], golden[3],
            golden[4], golden[5]
        }

        startRainbow:InvokeServer(ids)
        task.wait(30)

        claimRainbow:InvokeServer(ids[1])
        task.wait(1)
    end

    setInventory(false)
end

-- ================== FIND GEM MERCHANT ==================
local function runFindGem()

    print("🔍 FIND GEM MERCHANT START")
    task.wait(2.5)

    local player = game.Players.LocalPlayer

    local positions = {
        Vector3.new(-238.48,209.64,213.31),
        Vector3.new(-54.49,3496.82,443.35),
        Vector3.new(-274.58,5829.62,320.07),
        Vector3.new(-318.62,7569.88,196.95),
        Vector3.new(-401.06,9211.20,192.54),
        Vector3.new(-268.59,12933.14,286.36),
        Vector3.new(1430.87,644.48,-13152.08),
        Vector3.new(1406.43,1733.43,-13263.08),
        Vector3.new(1401.10,3131.77,-13176.44),
        Vector3.new(1380.25,5337.15,-13050.46)
    }

    local function getList()
        local success, result = pcall(function()
            return player
                :WaitForChild("PlayerGui")
                :WaitForChild("Tabs")
                :WaitForChild("Merchant")
                :WaitForChild("Menu")
                :WaitForChild("Inner")
                :WaitForChild("List")
        end)

        return success and result or nil
    end

    local function hasPotion(list)
        for _, obj in pairs(list:GetChildren()) do

            -- bỏ rác
            if obj:IsA("UIGridLayout") or obj.Name == "Template" then
                continue
            end

            if obj:IsA("Frame") then
                local name = string.lower(obj.Name)

                -- 🔥 chỉ cần chứa "potion"
                if string.find(name, "potion") then
                    return true
                end
            end
        end
        return false
    end

    for i, pos in ipairs(positions) do

        if not AutoSystem.enabled then break end

        local char = player.Character or player.CharacterAdded:Wait()
        local hrp = char:WaitForChild("HumanoidRootPart")

        hrp.CFrame = CFrame.new(pos)

        print("📍 Checking:", i)

        task.wait(1.5)

        local list = getList()

        if list and hasPotion(list) then
            print("✅ FOUND GEM MERCHANT!")
            return -- dừng mode
        end
    end

    print("❌ NOT FOUND GEM MERCHANT")
end
-- ================== POTION RUNNER ==================
local function runPotion()

    print("🧪 Run Potion Mode")

    teleportToPotion()

    -- 🔥 ĐỢI UI LOAD THẬT SỰ
    local potionMenu = player.PlayerGui:WaitForChild("Tabs")
        :WaitForChild("PotionMachine")
        :WaitForChild("Menu")

    -- đợi UI ổn định
    task.wait(2.5)

    -- 🔥 BƯỚC 1: ĐỌC TOÀN BỘ TEXT TRƯỚC
    local texts = {}
    -- 💰 LẤY GIÁ POTION
for _, slot in pairs({1,3,10}) do

    local success, priceLabel = pcall(function()
        return potionMenu
            :WaitForChild("BuyOptions")
            :WaitForChild("Buy"..slot)
            :WaitForChild("Main")
            :WaitForChild("Currency")
            :WaitForChild("Amount")
    end)

    if success and priceLabel then
        local price = parseNumber(priceLabel.Text)

        if price then
            potionPrices[slot] = price
            print("💰 PRICE SLOT", slot, "=", price)
        end
    else
        warn("❌ Không đọc được giá slot:", slot)
    end
end
    for _, slot in pairs({1,3,10}) do
        local success, path = pcall(function()
            return potionMenu.BuyOptions["Buy"..slot].Main.Cooldown
        end)

        if success and path then
            texts[slot] = path.Text
            print("📥 SLOT", slot, "TEXT:", texts[slot])
        else
            warn("❌ Không đọc được slot:", slot)
        end
    end

    -- 🔥 BƯỚC 2: XỬ LÝ SAU KHI ĐÃ CÓ TEXT
    for _, slot in pairs({1,3,10}) do
        if texts[slot] then
            handlePotion(slot, texts[slot])
        end
    end

end

-- ================== UPGRADE GEM ==================
local function runUpgradeGem()

    local JobID = game.JobId -- hoặc ID bạn đã xác định đúng

    local remote = game:GetService("ReplicatedStorage")
        :WaitForChild(JobID)
        :WaitForChild("Functions")
        :WaitForChild("UpgradeGemShop")

    -- 📌 danh sách + số lần
    local upgrades = {
        {Name = "FreeAutoClicker", Amount = 1},
        {Name = "HatchSpeed", Amount = 5},
        {Name = "CriticalChance", Amount = 5},
        {Name = "GoldenLuck", Amount = 6},
        {Name = "AutoClickerSpeed", Amount = 11},
        {Name = "ClickMultiplier", Amount = 20},
        {Name = "Teleport", Amount = 1},
    }

    for _, data in ipairs(upgrades) do
        local NameUpgradeGems = data.Name

        for i = 1, data.Amount do

            local args = {
                NameUpgradeGems
            }

            local success, err = pcall(function()
                remote:InvokeServer(unpack(args))
            end)

            if not success then
                warn("❌ lỗi:", NameUpgradeGems, err)
                break
            end

            print("⬆️", NameUpgradeGems, "(", i, "/", data.Amount, ")")

            task.wait(0.2)
        end
    end

    print("✅ DONE UPGRADE GEM")

end
-- 🔥 FORCE RUN FIND GEM 1 LẦN
task.spawn(function()
    task.wait(3)
    requestMode("FIND_GEM")
end)
-- ================== MAIN LOOP ==================
task.spawn(function()
    while true do

        if CurrentMode == "EGG" then
            CurrentMode = getNextMode()
            updateUI()
        end
        if CurrentMode == "POTION" then
            runPotion()
            eggTeleported = false
            CurrentMode = "EGG"

        elseif CurrentMode == "MINIGAME" then
            runMiniGame()
            eggTeleported = false
            CurrentMode = "EGG"

        elseif CurrentMode == "RAINBOW" then
            runRainbow()
            eggTeleported = false
            CurrentMode = "EGG"
        elseif CurrentMode == "TAP_LOOT" then
            runTapLoot()
            eggTeleported = false
            CurrentMode = "EGG"
        elseif CurrentMode == "FIND_GEM" then
            runFindGem()
            eggTeleported = false
            CurrentMode = "EGG"
        elseif CurrentMode == "EGG" then

            if AutoSystem.enabled then

                local ids = getPets()

                if AutoSystem.mode == "EGG" then

                    -- TELEPORT CHỈ 1 LẦN
                    if not eggTeleported then
                        eggTeleported = true

                        teleportPortal(PORTALS.EGG)
                        task.wait(1)

                        tp(POSITIONS.EGG)
                    end

                    -- HATCH LIÊN TỤC
                if #ids >= 6 then
                        AutoSystem.mode = "GOLDEN"
                elseif hatchFolder then
                        hatchFolder.Functions.OpenEgg:InvokeServer("Spring Blossom", AutoSystem.eggAmount)
                end

                elseif AutoSystem.mode == "GOLDEN" then
                    tp(POSITIONS.GOLDEN)

                    if #ids >= 6 and craftRemote then
                        craftRemote:InvokeServer({
                            ids[1], ids[2], ids[3],
                            ids[4], ids[5], ids[6]
                        })
                    else
                        AutoSystem.mode = "EGG"
                    end
                end

            end
        end

        task.wait(0.5)
    end
end)

-- ================== AUTO CLICK ==================
task.spawn(function()
    local baseX, baseY = 1050, 100

    while true do
        if AutoSystem.autoClick then
            pcall(function()
                local offsetX = math.random(-5,5)
                local offsetY = math.random(-5,5)

                mousemoveabs(baseX + offsetX, baseY + offsetY)
                mouse1click()
            end)
        end
        task.wait(0.05)
    end
end)

end
