    while true do
        if AutoSystem.enabled and not AutoSystem.isRainbowRunning then
            setInventory(true)
            waitForInventoryLoad(5)

            -- đợi 10 phút
            local t = 0
            while t < 600 do
                if not AutoSystem.enabled then break end
