local AutoSystem = {
    enabled = true,
    eggAmount = 8,
    mode = "EGG",
    isRainbowRunning = false,
    autoClick = true,
    miniGame = false,
    autoRebirthDelay = 60
}

-- ================== MODE QUEUE ==================
local ModeQueue = {}
local CurrentMode = "EGG"
local eggTeleported = false

local function requestMode(mode)
    -- tránh spam trùng
    if CurrentMode == mode then return end

    for _, m in pairs(ModeQueue) do
        if m == mode then return end
    end

    table.insert(ModeQueue, mode)
    print("📥 Queue:", mode)
end

local function getNextMode()
    if #ModeQueue == 0 then
        return "EGG"
    end

    local nextMode = table.remove(ModeQueue, 1)
    print("📤 Run:", nextMode)
    return nextMode
end

-- ================== SAVE ==================
local fileName = "auto_system.json"

pcall(function()
    if isfile(fileName) then
        local data = HttpService:JSONDecode(readfile(fileName))
        AutoSystem.eggAmount = data.eggAmount or 8
        AutoSystem.autoRebirthDelay = data.autoRebirthDelay or 60
        AutoSystem.enabled = data.enabled ~= nil and data.enabled or true
    end
end)

local function saveData()
    writefile(fileName, HttpService:JSONEncode({
        eggAmount = AutoSystem.eggAmount,
        enabled = AutoSystem.enabled,
        autoRebirthDelay = AutoSystem.autoRebirthDelay
    }))
end

