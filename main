-- ================== AUTO REBIRTH ==================
task.spawn(function()

    local player = game.Players.LocalPlayer

    -- UI PATH
    local label = player.PlayerGui
        :WaitForChild("RightHud")
        :WaitForChild("Main")
        :WaitForChild("RightUI")
        :WaitForChild("Rebirths")
        :WaitForChild("InfRebirths")
        :WaitForChild("Main")
        :WaitForChild("RebirthsAmount")
        :WaitForChild("Amount")

    -- PARSE
    local suffixMultiplier = {
        k = 1e3,
        m = 1e6,
        b = 1e9,
        t = 1e12,
        qd = 1e15,
        qn = 1e18,
        sx = 1e21
    }

    local function parseNumber(text)
        text = string.lower(text)

        local number, suffix = string.match(text, "([%d%.]+)%s*(%a+)")
        if not number then return nil end

        number = tonumber(number)
        if not number then return nil end

        if suffix and suffixMultiplier[suffix] then
            return number * suffixMultiplier[suffix]
        end

        return number
    end

    while true do
    task.wait(AutoSystem.autoRebirthDelay)

    local text = label.Text
    local value = parseNumber(text)

    if value then
        value = math.floor(value)

        print("♻️ Auto Rebirth:", value)

        pcall(function()
            game:GetService("ReplicatedStorage")
                :WaitForChild(game.JobId)
                :WaitForChild("Functions")
                :WaitForChild("Rebirth")
                :InvokeServer(1, value)
        end)
    else
        warn("❌ Rebirth parse fail:", text)
    end
    end

end)
-- ================== AUTO TAP LOOT SCHEDULER ==================
task.spawn(function()

    local nextTapLootTime = 0

    while true do
        local now = os.time()

        if now >= nextTapLootTime then
            requestMode("TAP_LOOT")
            nextTapLootTime = now + 3600 -- 🔥 1 tiếng
        end

        task.wait(10) -- check nhẹ
    end

end)

